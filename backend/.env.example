# Google Gemini API key (used by the LangGraph agent)
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model to use - keep configurable so it's easy to swap
GEMINI_MODEL=gemini-1.5-flash

# SQLite database location (relative to backend/)
DATABASE_URL=sqlite:///./database/app.db

# Where uploaded documents are stored
DOCUMENT_STORAGE_PATH=./storage/documents

# Base URL of the demo scholarship portal that Playwright automates
DEMO_PORTAL_URL=http://localhost:5173/demo-portal

# CORS - frontend origin
FRONTEND_ORIGIN=http://localhost:5173
